---
interface Props {
  title: string;
  description?: string;
  activePage?: string;
}

import '../styles/global.css';

const { title, description = 'llama.cpp benchmark results on AMD Strix Halo gfx1151 — RADV vs AMDVLK vs ROCm', activePage = '' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="theme-color" content="#FAFAF8" />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <title>{title} | Strix Benchmarks</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
</head>
<body>
  <nav>
    <div class="container">
      <a href={`${base}`} class="nav-brand">Strix Benchmarks</a>
      <button class="nav-hamburger" aria-label="Toggle menu">&#9776;</button>
      <ul class="nav-links">
        <li><a href={`${base}`} class={activePage === 'home' ? 'active' : ''}>Home</a></li>
        <li><a href={`${base}performance/`} class={activePage === 'performance' ? 'active' : ''}>Performance</a></li>
        <li><a href={`${base}creative-writing/`} class={activePage === 'creative' ? 'active' : ''}>Creative Writing</a></li>
        <li><a href={`${base}coding/`} class={activePage === 'coding' ? 'active' : ''}>Coding</a></li>
        <li><a href={`${base}quantization/`} class={activePage === 'quantization' ? 'active' : ''}>Quantization</a></li>
      </ul>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer>
    <p>Strix Benchmarks &mdash; AMD Strix Halo gfx1151 &mdash; Updated March 2026</p>
    <p><a href="https://github.com/slb350/strix-benchmarks">Source on GitHub</a></p>
  </footer>

  <script>
    document.querySelector('.nav-hamburger')?.addEventListener('click', () => {
      document.querySelector('.nav-links')?.classList.toggle('open');
    });
  </script>
</body>
</html>
