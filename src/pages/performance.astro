---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Performance" activePage="performance" description="llama-bench results across RADV, AMDVLK, and ROCm on AMD Strix Halo gfx1151">
  <div class="page-header fade-up">
    <h1>Performance Benchmarks</h1>
    <p class="description">llama-bench pp512/tg128 results across all three backends. Click column headers to sort. Config: ngl=999, batch=2048, threads=32, FA=1.</p>
  </div>

  <h2>Active Models on Disk</h2>
  <div class="table-wrap fade-up">
    <table class="sortable">
      <thead>
        <tr>
          <th>Model</th>
          <th>Quant</th>
          <th>Size</th>
          <th>Backend</th>
          <th data-type="number">pp512 (t/s)</th>
          <th data-type="number">tg128 (t/s)</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="model-name">GPT-OSS-20B-Derestricted</td><td>MXFP4</td><td>11 GiB</td><td>RADV</td><td class="best">1424</td><td>80</td></tr>
        <tr><td class="model-name">GPT-OSS-20B-Derestricted</td><td>MXFP4</td><td>11 GiB</td><td>AMDVLK</td><td>1161</td><td class="best">81</td></tr>
        <tr><td class="model-name">GPT-OSS-20B-Derestricted</td><td>MXFP4</td><td>11 GiB</td><td>ROCm</td><td>1302</td><td>71</td></tr>
        <tr><td class="model-name">Qwen3-30B-Instruct-2507</td><td>Q6_K</td><td>23 GiB</td><td>RADV</td><td class="best">1055</td><td class="best">75</td></tr>
        <tr><td class="model-name">Qwen3-30B-Instruct-2507</td><td>Q6_K</td><td>23 GiB</td><td>ROCm</td><td>1026</td><td>63</td></tr>
        <tr><td class="model-name">Qwen3-30B-Instruct-2507</td><td>Q6_K</td><td>23 GiB</td><td>AMDVLK</td><td>833</td><td>70</td></tr>
        <tr><td class="model-name">GPT-OSS-120B</td><td>MXFP4</td><td>59 GiB</td><td>AMDVLK</td><td class="best">661</td><td>53</td></tr>
        <tr><td class="model-name">GPT-OSS-120B</td><td>MXFP4</td><td>59 GiB</td><td>RADV</td><td>596</td><td class="best">56</td></tr>
        <tr><td class="model-name">GPT-OSS-120B</td><td>MXFP4</td><td>59 GiB</td><td>ROCm</td><td>272</td><td>50</td></tr>
        <tr><td class="model-name">Qwen3-Coder-Next-80B</td><td>MXFP4</td><td>41 GiB</td><td>RADV</td><td class="best">586</td><td>40</td></tr>
        <tr><td class="model-name">Qwen3-Coder-Next-80B</td><td>MXFP4</td><td>41 GiB</td><td>AMDVLK</td><td>462</td><td class="best">43</td></tr>
        <tr><td class="model-name">Qwen3-Coder-Next-80B</td><td>MXFP4</td><td>41 GiB</td><td>ROCm</td><td>383</td><td>38</td></tr>
        <tr><td class="model-name">Qwen3.5-122B-A10B</td><td>Unsloth UD-Q4_K_XL</td><td>72 GiB</td><td>RADV</td><td class="best">258</td><td>19.6</td></tr>
        <tr><td class="model-name">Qwen3.5-122B-A10B</td><td>Unsloth UD-Q4_K_XL</td><td>72 GiB</td><td>AMDVLK</td><td>183</td><td class="best">20.7</td></tr>
        <tr><td class="model-name">Qwen3.5-9B</td><td>Q8_0</td><td>9 GiB</td><td>RADV</td><td class="best">866</td><td>22.5</td></tr>
        <tr><td class="model-name">Qwen3.5-9B</td><td>Q8_0</td><td>9 GiB</td><td>ROCm</td><td>562</td><td>22.3</td></tr>
        <tr><td class="model-name">Qwen3.5-9B</td><td>Q8_0</td><td>9 GiB</td><td>AMDVLK</td><td>285</td><td class="best">23.3</td></tr>
        <tr><td class="model-name">Qwen3.5-4B</td><td>Q8_0</td><td>4 GiB</td><td>RADV</td><td class="best">1375</td><td>37.9</td></tr>
        <tr><td class="model-name">Qwen3.5-4B</td><td>Q8_0</td><td>4 GiB</td><td>ROCm</td><td>958</td><td>36.3</td></tr>
        <tr><td class="model-name">Qwen3.5-4B</td><td>Q8_0</td><td>4 GiB</td><td>AMDVLK</td><td>510</td><td class="best">40.0</td></tr>
      </tbody>
    </table>
  </div>

  <h2>Tested & Removed Models</h2>
  <div class="table-wrap fade-up">
    <table class="sortable">
      <thead>
        <tr>
          <th>Model</th>
          <th>Quant</th>
          <th>Size</th>
          <th>Backend</th>
          <th data-type="number">pp512 (t/s)</th>
          <th data-type="number">tg128 (t/s)</th>
        </tr>
      </thead>
      <tbody>
        <tr><td class="model-name">GLM-4.7-Flash</td><td>Q4_K_M</td><td>17 GiB</td><td>RADV</td><td>949</td><td>75</td></tr>
        <tr><td class="model-name">GLM-4.7-Flash</td><td>Q4_K_M</td><td>17 GiB</td><td>ROCm</td><td>966</td><td>51</td></tr>
        <tr><td class="model-name">GLM-4.7-Flash</td><td>Q4_K_M</td><td>17 GiB</td><td>AMDVLK</td><td>578</td><td>78</td></tr>
        <tr><td class="model-name">GLM-4.7-Flash</td><td>BF16</td><td>56 GiB</td><td>ROCm</td><td>422</td><td>22</td></tr>
        <tr><td class="model-name">Kimi-Linear-48B</td><td>Q5_K_M</td><td>33 GiB</td><td>RADV</td><td>285</td><td>65</td></tr>
        <tr><td class="model-name">Kimi-Linear-48B</td><td>Q5_K_M</td><td>33 GiB</td><td>AMDVLK</td><td>238</td><td>63</td></tr>
        <tr><td class="model-name">Kimi-Linear-48B</td><td>Q5_K_M</td><td>33 GiB</td><td>ROCm</td><td>303</td><td>55</td></tr>
        <tr><td class="model-name">Step3.5-Flash</td><td>IQ3_XS</td><td>76 GiB</td><td>RADV</td><td>237</td><td>32</td></tr>
        <tr><td class="model-name">MiniMax-M2.5</td><td>IQ3_XXS</td><td>87 GiB</td><td>RADV</td><td>203</td><td>37</td></tr>
        <tr><td class="model-name">GLM-4.7-Flash-Opus-Distill</td><td>Q8_0</td><td>30 GiB</td><td>RADV</td><td>981</td><td>50</td></tr>
        <tr><td class="model-name">Qwen3.5-27B</td><td>UD-Q4_K_XL</td><td>16 GiB</td><td>ROCm</td><td>326</td><td>11.28</td></tr>
        <tr><td class="model-name">Qwen3.5-27B</td><td>UD-Q4_K_XL</td><td>16 GiB</td><td>RADV</td><td>269</td><td>11.35</td></tr>
        <tr><td class="model-name">Qwen3.5-35B-A3B</td><td>AesSedai Q4_K_M</td><td>21 GiB</td><td>RADV</td><td>832</td><td>48</td></tr>
        <tr><td class="model-name">Qwen3.5-35B-A3B</td><td>AesSedai Q4_K_M</td><td>21 GiB</td><td>AMDVLK</td><td>591</td><td>53</td></tr>
      </tbody>
    </table>
  </div>

  <div class="divider"></div>

  <h2>Key Findings</h2>
  <ul class="findings fade-up">
    <li><strong>RADV is the default recommendation</strong> since b8119 MMQ fix gave it a 25% pp boost on Qwen3-30B. It now beats AMDVLK on most models.</li>
    <li><strong>AMDVLK excels on GPT-OSS-120B pp</strong> (661 vs 596 RADV) and provides the best tg on several MoE models.</li>
    <li><strong>ROCm requires <code>-mmp 0</code></strong> or models hang during load. Best for GLM-4.7 and Qwen3.5-27B dense. Crashes with FA enabled on GPT-OSS-120B.</li>
    <li><strong>Batch size 2048 is optimal</strong> for RDNA 3.5 &mdash; higher values (4096+) decrease performance.</li>
    <li><strong>MXFP4 quants outperform Q4_K_M</strong> for MoE models when QAT-trained (e.g., GPT-OSS-120B). Post-hoc MXFP4 on BF16 underperforms standard quants.</li>
    <li><strong>Qwen3.5 dense models have an architecture-level tg bottleneck</strong> &mdash; 6-11 t/s for 27B, 22-23 t/s for 9B regardless of backend.</li>
  </ul>

  <script is:inline>
    document.querySelectorAll('table.sortable th').forEach((th, i) => {
      const arrow = document.createElement('span');
      arrow.className = 'sort-arrow';
      arrow.textContent = ' \u25B4';
      th.appendChild(arrow);
      let asc = true;
      th.addEventListener('click', () => {
        const table = th.closest('table');
        const tbody = table?.querySelector('tbody');
        if (!table || !tbody) return;
        const rows = Array.from(tbody.querySelectorAll('tr'));
        const isNum = th.dataset.type === 'number';
        table.querySelectorAll('.sort-arrow').forEach(a => { a.classList.remove('active'); a.textContent = ' \u25B4'; });
        arrow.classList.add('active');
        arrow.textContent = asc ? ' \u25B4' : ' \u25BE';
        rows.sort((a, b) => {
          const av = a.children[i]?.textContent?.trim() ?? '';
          const bv = b.children[i]?.textContent?.trim() ?? '';
          if (isNum) return asc ? parseFloat(av) - parseFloat(bv) : parseFloat(bv) - parseFloat(av);
          return asc ? av.localeCompare(bv) : bv.localeCompare(av);
        });
        rows.forEach(r => tbody.appendChild(r));
        asc = !asc;
      });
    });
  </script>
</BaseLayout>
