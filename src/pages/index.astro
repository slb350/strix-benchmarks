          <th data-type="number">Polyglot /65</th>
          <th data-type="number">Postgres /57</th>
          <th data-type="number">Cassandra /56</th>
          <th data-type="number">Combined /285</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="model-name">Nemotron-3-Nano-Omni-30B-A3B-Reasoning</td>
          <td>Hybrid MoE (3B active)</td>
          <td>22.8 GiB</td>
          <td>1097</td>
          <td>61.1</td>
          <td>24</td>
          <td>6</td>
          <td>31</td>
