          <td>26</td>
          <td>17</td>
        </tr>
        <tr>
          <td class="model-name">Gemma-4-26B-A4B</td>
          <td>MoE (4B active)</td>
          <td>16 GiB</td>
          <td>1196</td>
          <td>52.9</td>
          <td>23</td>
          <td>10</td>
          <td>44</td>
          <td class="best">30</td>
        </tr>
        <tr>
          <td class="model-name">Gemma-4-31B</td>
          <td>Dense</td>
          <td>17.5 GiB</td>
          <td>247</td>
          <td>11.1</td>
