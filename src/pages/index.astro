          <th data-type="number">Polyglot /65</th>
          <th data-type="number">Postgres /57</th>
          <th data-type="number">Cassandra /56</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td class="model-name">Gemma-4-E2B</td>
